{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Ecosystem parity specification — single source of truth for structural requirements across all Lidarr plugin repos.",
  "version": "1.0.0",

  "requiredFiles": [
    { "path": "global.json", "description": "SDK version pin" },
    { "path": "VERSION", "description": "Version file for builds" },
    { "path": "Directory.Build.props", "description": "Shared MSBuild properties" },
    { "path": "Directory.Packages.props", "description": "Central Package Management" },
    { "path": ".gitleaks.toml", "description": "Secret scanning configuration" },
    { "path": ".markdownlint.yaml", "description": "Markdown linting rules" },
    { "path": ".github/CODEOWNERS", "description": "Code ownership" },
    { "path": ".github/dependabot.yml", "description": "Automated dependency updates" },
    { "path": ".github/sha-pin-allowlist.json", "description": "SHA pin exception tracking" }
  ],

  "requiredDirectories": [
    { "path": ".github/ISSUE_TEMPLATE", "minFiles": 2, "description": "Issue templates (bug + feature minimum)" }
  ],

  "requiredCiWorkflow": {
    "path": ".gitea/workflows/ci.yml",
    "description": "Primary Gitea CI workflow"
  },

  "globalJson": {
    "sdk": {
      "version": "8.0.100",
      "rollForward": "latestFeature",
      "allowPrerelease": false
    }
  },

  "directoryBuildProps": {
    "requiredProperties": [
      { "name": "ILRepackEnabled", "value": "false", "description": "ILRepack disabled (use PluginPackaging.targets)" },
      { "name": "Deterministic", "value": "true", "description": "Deterministic builds" },
      { "name": "Nullable", "value": "enable", "description": "Nullable reference types" },
      { "name": "LangVersion", "value": "latest", "description": "Latest C# language version" },
      { "name": "PublishRepositoryUrl", "value": "true", "description": "SourceLink support" },
      { "name": "EmbedUntrackedSources", "value": "true", "description": "SourceLink support" }
    ],
    "requiredPackageReferences": [
      { "include": "Microsoft.SourceLink.GitHub", "description": "SourceLink for deterministic builds" }
    ],
    "requiredConditions": [
      { "description": "CPM exclusion for ext/ submodule", "pattern": "ManagePackageVersionsCentrally.*false" }
    ],
    "requiredSections": [
      { "name": "VersionManagement", "marker": "VersionFromFile", "description": "VERSION file integration" },
      { "name": "NoWarnSuppression", "marker": "NoWarn", "description": "Warning suppressions for Lidarr compat" }
    ]
  },

  "directoryPackagesProps": {
    "requiredProperties": [
      { "name": "ManagePackageVersionsCentrally", "value": "true", "description": "CPM enabled" }
    ]
  },

  "pluginJson": {
    "requiredFields": [
      "id", "apiVersion", "name", "version", "author", "description",
      "homepage", "license", "tags", "commonVersion", "minHostVersion",
      "targetFramework", "main", "rootNamespace"
    ],
    "targetFramework": "net8.0",
    "forbiddenFields": [
      { "field": "minimumVersion", "reason": "Use minHostVersion instead (non-standard duplication)" },
      { "field": "targets", "reason": "Use targetFramework string instead of targets array" }
    ]
  },

  "manifestJson": {
    "targetFrameworks": ["net8.0"],
    "forbiddenTargetFrameworks": ["net6.0"],
    "forbiddenFields": [
      { "field": "minimumVersion", "reason": "Use minHostVersion instead (non-standard duplication)" },
      { "field": "targets", "reason": "Use targetFrameworks array instead of targets" }
    ]
  },

  "versionContract": {
    "description": "Ecosystem version contract (Phase 0.3). Lint resolves canonical commonVersion from commonVersionSource at runtime. Directory.Build.props is the single source of truth for Common and Abstractions package versions. Plugins must declare a matching commonVersion in plugin.json; intra-repo plugin.json/manifest.json version drift is forbidden.",
    "commonVersionSource": "Directory.Build.props",
    "targetFramework": "net8.0",
    "forbiddenTargetFrameworks": ["net6.0", "net7.0", "netstandard2.0", "netstandard2.1"],
    "allowedHostAssemblies": [
      "Lidarr.Core.dll",
      "Lidarr.Common.dll",
      "Lidarr.Http.dll",
      "Lidarr.Api.V1.dll",
      "Lidarr.Plugin.Abstractions.dll"
    ],
    "forbiddenPackageContents": [
      "FluentValidation.dll",
      "NLog.dll",
      "System.Text.Json.dll",
      "Microsoft.Extensions.DependencyInjection.Abstractions.dll",
      "Microsoft.Extensions.Logging.Abstractions.dll",
      "Microsoft.Extensions.Logging.dll",
      "Microsoft.Extensions.Configuration.dll",
      "Microsoft.Extensions.Caching.Memory.dll",
      "Microsoft.Extensions.Http.dll",
      "Lidarr.Plugin.Abstractions.dll",
      "Lidarr.Plugin.Common.dll",
      "Lidarr.Core.dll",
      "Lidarr.Common.dll",
      "Lidarr.Http.dll",
      "Lidarr.Api.V1.dll",
      "NzbDrone.Core.dll",
      "NzbDrone.Common.dll"
    ]
  }
}
